#!/usr/bin/env fish
# aho-models — Declarative Ollama model fleet wrapper.
# Reads from artifacts/harness/model-fleet.txt.
# Subcommands: list, status, install, vet, doctor
#
# Tier 1 finalized 0.2.16 W0 per 0.2.15 tier1-roster-validation:
#   qwen3.5:9b (operational), llama3.2:3b (operational),
#   haervwe/GLM-4.6V-Flash-9B:latest (partial, retain),
#   nemotron-mini:4b (compromised, classifier-role only).

set -g script_name "aho-models"
set -g project_root (dirname (dirname (realpath (status filename))))
set -g fleet_file "$project_root/artifacts/harness/model-fleet.txt"

function _info
    set_color cyan; echo "[$script_name] $argv"; set_color normal
end

function _warn
    set_color yellow; echo "[$script_name WARN] $argv"; set_color normal
end

function _error
    set_color red; echo "[$script_name ERROR] $argv"; set_color normal
end

function _gap
    set_color red; echo "[CAPABILITY GAP] $argv"; set_color normal
end

function _parse_fleet
    if not test -f $fleet_file
        _error "Fleet file not found: $fleet_file"
        return 1
    end
    grep -v '^\s*#' $fleet_file | grep -v '^\s*$' | string trim; or true
end

function _check_ollama
    if not command -q ollama
        _gap "ollama not found on PATH. Install via pacman or upstream script."
        return 1
    end
    if not curl -s http://localhost:11434/api/tags >/dev/null 2>&1
        # Ollama runs as SYSTEM-level systemd (/etc/systemd/system/ollama.service),
        # not user. Restart requires sudo. (0.2.15 W1 F008 / E2 — documented at
        # Tier 1.)
        _gap "Ollama daemon not reachable at localhost:11434. Start it: sudo systemctl start ollama"
        return 1
    end
    return 0
end

function _check_vram
    # Tier 1 requires a GPU with >=8GB VRAM. GLM-4.6V-Flash-9B needs num_gpu=30
    # partial offload at 8GB (0.2.15 W1 R2); full 41-layer offload OOMs.
    if not command -q nvidia-smi
        _gap "nvidia-smi not found. Tier 1 requires an NVIDIA GPU with 8GB+ VRAM."
        return 1
    end
    set -l total_mib (nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 | string trim)
    if test -z "$total_mib"
        _gap "Could not read nvidia-smi memory.total. Driver installed?"
        return 1
    end
    if test "$total_mib" -lt 8000
        _gap "GPU VRAM $total_mib MiB below Tier 1 minimum (8000 MiB). Halt."
        return 1
    end
    _info "GPU VRAM $total_mib MiB meets Tier 1 minimum."
    return 0
end

function _installed_models
    ollama list 2>/dev/null | tail -n +2 | awk '{print $1}'
end

function _cmd_list
    set -l models (_parse_fleet)
    for m in $models
        echo $m
    end
end

function _cmd_status
    _check_ollama; or return 1
    set -l models (_parse_fleet)
    set -l installed (_installed_models)
    set -l present 0
    set -l missing_count 0
    for m in $models
        set -l found 0
        for i in $installed
            if test "$i" = "$m"
                set found 1
                break
            end
        end
        if test $found -eq 1
            set_color green; echo "  [pulled]  $m"; set_color normal
            set present (math $present + 1)
        else
            set_color red; echo "  [missing] $m"; set_color normal
            set missing_count (math $missing_count + 1)
        end
    end
    _info "$present pulled, $missing_count missing out of "(count $models)" declared models"
end

function _cmd_install
    _check_vram; or return 1
    _check_ollama; or return 1
    set -l models (_parse_fleet)
    if test (count $models) -eq 0
        _info "No models declared."
        return 0
    end
    _info "Pulling "(count $models)" Tier 1 models..."
    for m in $models
        _info "Pulling $m..."
        ollama pull $m
        if test $status -ne 0
            _error "Failed to pull $m"
            return 1
        end
    end
    _info "Tier 1 model pull complete. Deferred (not-installed) roster in"
    _info "artifacts/harness/model-fleet.txt; see comments for rationale."
    _info "Next step: run 'aho-models vet' to smoke-probe each model."
end

function _cmd_vet
    # Minimal per-model smoke probe: /api/chat with a one-line user prompt,
    # expect non-empty response. Diagnoses gross dispatch regressions at
    # clone-to-deploy time. Not a substitute for 0.2.15 W0 per-model vetting
    # (tier1-roster-validation) which ran three probes per model and classified
    # operational/partial/compromised.
    _check_ollama; or return 1
    set -l models (_parse_fleet)
    set -l failures 0
    for m in $models
        _info "Vet $m ..."
        # num_predict=256 leaves budget for Qwen thinking-mode (which can
        # consume 150-200 tokens on a short response) plus a brief content
        # reply. 32 tokens is too small — 0.2.16 W0 vet run saw Qwen emit
        # 0-char content with num_predict=32 because thinking exhausted the
        # budget.
        set -l body '{"model":"'$m'","messages":[{"role":"user","content":"Reply with the single word: OK"}],"stream":false,"options":{"num_predict":256}}'
        set -l resp (curl -s -X POST http://localhost:11434/api/chat \
            -H 'Content-Type: application/json' \
            -d "$body" 2>&1)
        set -l chars (echo "$resp" | python -c 'import sys,json
try:
    d=json.loads(sys.stdin.read())
    print(len((d.get("message") or {}).get("content","")))
except Exception:
    print(0)' 2>/dev/null)
        if test -z "$chars"; or test "$chars" = "0"
            _warn "  $m emitted 0-char content — FAIL"
            set failures (math $failures + 1)
        else
            _info "  $m emitted $chars chars — ok"
        end
    end
    if test $failures -gt 0
        _error "$failures of "(count $models)" models failed vet."
        return 1
    end
    _info "All "(count $models)" Tier 1 models passed smoke vet."
end

function _cmd_doctor
    _check_ollama; or return 1
    set -l models (_parse_fleet)
    set -l installed (_installed_models)
    set -l missing
    for m in $models
        set -l found 0
        for i in $installed
            if test "$i" = "$m"
                set found 1
                break
            end
        end
        if test $found -eq 0
            set -a missing $m
        end
    end
    if test (count $missing) -gt 0
        _error "Missing models: $missing"
        return 1
    end
    _info "All "(count $models)" declared models present."
    return 0
end

switch "$argv[1]"
    case list
        _cmd_list
    case status
        _cmd_status
    case install
        _cmd_install
    case vet
        _cmd_vet
    case doctor
        _cmd_doctor
    case '*'
        echo "Usage: $script_name {list|status|install|vet|doctor}"
        exit 1
end
