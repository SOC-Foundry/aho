#!/usr/bin/env fish
# aho-mcp - Global MCP server fleet manager for aho.
# 0.2.4 W1 — 9-package canonical list, registry-verified.

set -g script_version "0.2.8"

set -g mcp_packages \
    firebase-tools \
    @upstash/context7-mcp \
    firecrawl-mcp \
    @playwright/mcp \
    @modelcontextprotocol/server-filesystem \
    @modelcontextprotocol/server-memory \
    @modelcontextprotocol/server-sequential-thinking \
    @modelcontextprotocol/server-everything

function _info
    set_color cyan; echo "[aho-mcp] $argv"; set_color normal
end

function _warn
    set_color yellow; echo "[aho-mcp WARN] $argv"; set_color normal
end

function _error
    set_color red; echo "[aho-mcp ERROR] $argv"; set_color normal
end

function _check_npm
    if not command -q npm
        _error "npm not found on PATH"
        exit 1
    end
end

function _is_installed
    npm list -g --depth=0 2>/dev/null | grep -q $argv[1]
end

function mcp_list
    _info "MCP Server Fleet ($script_version)"
    _info "---"
    for pkg in $mcp_packages
        if _is_installed $pkg
            set_color green; echo "  [ok] $pkg"; set_color normal
        else
            set_color red; echo "  [--] $pkg (not installed)"; set_color normal
        end
    end
end

function mcp_status
    _check_npm
    set -l installed 0
    set -l missing 0
    for pkg in $mcp_packages
        if _is_installed $pkg
            set installed (math $installed + 1)
        else
            set missing (math $missing + 1)
        end
    end
    _info "Installed: $installed / "(count $mcp_packages)
    if test $missing -gt 0
        _warn "Missing: $missing packages"
    end
end

function mcp_doctor
    _check_npm
    set -l all_ok 1
    for pkg in $mcp_packages
        if not _is_installed $pkg
            _error "MISSING: $pkg"
            set all_ok 0
        end
    end
    if test $all_ok -eq 1
        _info "All "(count $mcp_packages)" MCP servers present. OK."
    else
        _error "Some MCP servers missing. Run: bin/aho-mcp install"
    end

    # Registry verification pass (G-mcp-canonical-drift defense)
    _info "Registry verification..."
    set -l reg_ok 1
    for pkg in $mcp_packages
        set -l npm_out (npm view $pkg version 2>&1)
        if test $status -ne 0
            _error "REGISTRY 404: $pkg"
            set reg_ok 0
        else if string match -q '*deprecated*' -- $npm_out
            _error "DEPRECATED: $pkg"
            set reg_ok 0
        end
    end
    if test $reg_ok -eq 1
        _info "All "(count $mcp_packages)" packages registry-verified. OK."
    else
        _error "Registry verification failed. Review canonical list."
    end
end

function mcp_install
    _check_npm
    for pkg in $mcp_packages
        if not _is_installed $pkg
            _info "Installing $pkg..."
            sudo npm install -g $pkg; or echo "[CAPABILITY GAP] sudo npm install failed for $pkg"
        else
            _info "$pkg already installed."
        end
    end
    _info "MCP fleet install complete."
end

function mcp_smoke
    set -l smoke_dir (status dirname)/../artifacts/scripts/mcp-smoke
    if not test -d $smoke_dir
        _error "Smoke scripts directory not found: $smoke_dir"
        exit 1
    end

    set -l scripts (command ls $smoke_dir/*.fish 2>/dev/null)
    if test (count $scripts) -eq 0
        _error "No smoke scripts found in $smoke_dir"
        exit 1
    end

    set -l total (count $scripts)
    set -l passed 0
    set -l failed 0
    set -l names
    set -l statuses
    set -l results_json "["
    set -l first 1

    _info "MCP Smoke Test Suite ($script_version)"
    _info "Running $total server smoke tests..."
    _info "---"

    for script in $scripts
        set -l name (basename $script .fish)
        set -l output (fish $script 2>&1)
        set -l exit_code $status
        set -l status_str

        if test $exit_code -eq 0
            set passed (math $passed + 1)
            set status_str "pass"
            set_color green; echo "  [pass] $name"; set_color normal
        else
            set failed (math $failed + 1)
            set status_str "fail"
            set_color red; echo "  [FAIL] $name"; set_color normal
            echo "         $output" >&2
        end

        set -a names $name
        set -a statuses $status_str

        if test $first -eq 1
            set first 0
        else
            set results_json "$results_json,"
        end
        set results_json "$results_json{\"server\":\"$name\",\"cli_smoke\":\"$status_str\",\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}"
    end

    set results_json "$results_json]"

    _info "---"
    _info "Results: $passed/$total pass, $failed fail"

    # Write JSON sidecar
    set -l json_path (status dirname)/../data/mcp_readiness.json
    printf '%s\n' "{\"version\":\"$script_version\",\"timestamp\":\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\",\"total\":$total,\"passed\":$passed,\"failed\":$failed,\"results\":$results_json}" > $json_path
    _info "JSON sidecar written to data/mcp_readiness.json"

    # Write markdown report
    set -l iteration (python3 -c "import json; print(json.load(open('.aho.json'))['current_iteration'])" 2>/dev/null; or echo "unknown")
    set -l md_path (status dirname)/../artifacts/iterations/$iteration/mcp-readiness.md
    printf '# MCP Fleet Readiness — %s\n\n' $iteration > $md_path
    printf '**Date:** %s\n' (date -u +%Y-%m-%dT%H:%M:%SZ) >> $md_path
    printf '**Total:** %d | **Pass:** %d | **Fail:** %d\n\n' $total $passed $failed >> $md_path
    printf '| Server | CLI Smoke |\n' >> $md_path
    printf '|---|---|\n' >> $md_path

    for i in (seq (count $names))
        if test $statuses[$i] = "pass"
            printf '| %s | pass |\n' $names[$i] >> $md_path
        else
            printf '| %s | **FAIL** |\n' $names[$i] >> $md_path
        end
    end

    printf '\n---\n\n*Generated by bin/aho-mcp smoke*\n' >> $md_path
    _info "Readiness report written to artifacts/iterations/$iteration/mcp-readiness.md"

    if test $failed -gt 0
        exit 1
    end
end

# Dispatch subcommand
switch $argv[1]
    case list
        mcp_list
    case status
        mcp_status
    case doctor
        mcp_doctor
    case install
        mcp_install
    case smoke
        mcp_smoke
    case '*'
        _info "Usage: aho-mcp {list|status|doctor|install|smoke}"
        _info "  list    - Show all MCP servers and their install status"
        _info "  status  - Summary of installed vs missing"
        _info "  doctor  - Verify all 9 servers present + registry check"
        _info "  install - Install missing servers globally via npm"
        _info "  smoke   - Run per-server smoke tests, output readiness report"
end
