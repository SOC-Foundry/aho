#!/usr/bin/env fish
# aho-secrets-init — Age keygen + OS keyring + telegram verification + brave token.
# Absorbs 0.2.3 W4 age keygen logic from bin/aho-bootstrap.
# 0.2.7 W5 — adds --add-brave-token and orchestrator.json init.
# Usage: bin/aho-secrets-init [--force] [--add-brave-token]

set -g script_name "aho-secrets-init"
set -g project_root (dirname (dirname (realpath (status filename))))
set -g age_key "$HOME/.config/aho/age.key"
set -g secrets_store "$HOME/.config/aho/secrets.fish.fernet"
set -g orchestrator_config "$HOME/.config/aho/orchestrator.json"
set -g force_mode 0
set -g add_brave 0

for arg in $argv
    switch $arg
        case --force
            set force_mode 1
        case --add-brave-token
            set add_brave 1
    end
end

function _info
    set_color cyan; echo "[$script_name] $argv"; set_color normal
end

function _warn
    set_color yellow; echo "[$script_name WARN] $argv"; set_color normal
end

function _error
    set_color red; echo "[$script_name ERROR] $argv"; set_color normal
end

function _gap
    set_color red; echo "[CAPABILITY GAP] $argv"; set_color normal
end

# --- Age key ---

function _init_age_key
    mkdir -p (dirname $age_key)

    if test -f $age_key
        if test $force_mode -eq 1
            _warn "Age key exists. --force specified but refusing to overwrite."
            _warn "Delete $age_key manually if you really want to regenerate."
            return 1
        end
        _info "Age key present at $age_key"
        return 0
    end

    if not command -q age-keygen
        _gap "age-keygen not found. Install age: sudo pacman -S age"
        return 1
    end

    _info "Generating age key..."
    age-keygen -o $age_key
    if test $status -ne 0
        _error "age-keygen failed."
        return 1
    end
    chmod 600 $age_key
    _info "Age key generated at $age_key"
    echo "BACK IT UP NOW. Without it, all encrypted secrets are unrecoverable."
end

# --- OS keyring bootstrap ---

function _init_keyring
    if not command -q secret-tool
        _warn "secret-tool not found. Install libsecret for keyring support."
        return 0
    end
    _info "OS keyring backend (libsecret) available."
end

# --- Secrets store ---

function _check_secrets_store
    if test -f $secrets_store -a -s $secrets_store
        _info "Secrets store present at $secrets_store"
        return 0
    end

    _gap "Secrets store not found. Run: aho secret unlock (then set telegram secrets via aho secret set)"
    return 1
end

# --- Telegram verification ---

function _check_telegram
    # Check if aho-telegram daemon is running
    set -l daemon_status (systemctl --user is-active aho-telegram 2>/dev/null)
    if test "$daemon_status" = "active"
        # Query daemon for bot status via socket
        set -l sock "$HOME/.local/share/aho/telegram.sock"
        if test -S $sock
            set -l reply (echo '{"cmd":"status"}' | socat - UNIX-CONNECT:$sock 2>/dev/null)
            if test -n "$reply"
                set -l has_token (echo $reply | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('has_token','false'))" 2>/dev/null)
                if test "$has_token" = "True"
                    _info "Telegram daemon active, bot token configured."
                    return 0
                end
            end
        end
        _info "Telegram daemon active (socket query skipped)."
        return 0
    end

    # Daemon not running — check if secrets store has telegram keys
    # (can't decrypt without unlock, but if the store file exists and
    # the daemon ran before, secrets are likely present)
    if test -f $secrets_store -a -s $secrets_store
        _info "Telegram daemon not running but secrets store present."
        _info "Start daemon: systemctl --user start aho-telegram"
        return 0
    end

    _gap "Telegram not configured. Set secrets via: aho secret set ahomw telegram_bot_token <token>"
    return 1
end

# --- Orchestrator config ---

function _init_orchestrator_config
    if test -f $orchestrator_config
        _info "Orchestrator config present at $orchestrator_config"
        return 0
    end
    _info "Creating default orchestrator config..."
    mkdir -p (dirname $orchestrator_config)
    set -x AHO_PROJECT_ROOT $project_root
    python3 -c "from aho.orchestrator_config import ensure_config; ensure_config()"
    if test $status -ne 0
        _error "Failed to create orchestrator config."
        return 1
    end
    _info "Orchestrator config created at $orchestrator_config"
end

# --- Brave token ---

function _add_brave_token
    _info "Adding Brave Search API token..."

    if not test -f $secrets_store -a -s $secrets_store
        _error "Secrets store not initialized. Run bin/aho-secrets-init first."
        return 1
    end

    printf "Paste Brave Search API key (input hidden): "
    stty -echo
    read -l brave_token
    stty echo
    printf "\n"

    if test -z "$brave_token"
        _error "Token is empty. Aborting."
        return 1
    end

    # Validate: non-empty, reasonable length
    set -l token_len (string length $brave_token)
    if test $token_len -lt 10
        _error "Token seems too short ($token_len chars). Aborting."
        return 1
    end

    # Store in fernet secrets under project ahomw
    set -x AHO_PROJECT_ROOT $project_root
    python3 -c "
from aho.secrets.store import add_secret
add_secret('ahomw', 'brave_search_token', '$brave_token')
print('[aho-secrets-init] Brave Search token stored.')
"
    if test $status -ne 0
        _error "Failed to store brave token."
        return 1
    end

    # Ensure orchestrator.json references the key
    _init_orchestrator_config

    _info "Brave Search token stored. Verify with: bin/aho-secrets-init list"
end

# --- List secrets ---

function _list_secrets
    set -x AHO_PROJECT_ROOT $project_root
    python3 -c "
from aho.secrets.store import list_secret_names
names = list_secret_names()
if names:
    for n in names:
        print(f'  {n}')
else:
    print('  (no secrets stored)')
"
end

# --- Main ---

# Dispatch --add-brave-token subcommand
if test $add_brave -eq 1
    _add_brave_token
    exit $status
end

# Dispatch list subcommand
if test "$argv[1]" = "list"
    _list_secrets
    exit $status
end

_info "Initializing aho secrets..."

_init_age_key; or exit 1
_init_keyring
_check_secrets_store; or exit 1
_check_telegram; or exit 1
_init_orchestrator_config; or exit 1

_info "Secrets initialization complete."
