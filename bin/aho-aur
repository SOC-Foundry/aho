#!/usr/bin/env fish
# aho-aur — Declarative AUR package manager wrapper.
# Reads from artifacts/harness/aur-packages.txt.
# Bootstraps yay if missing.
# Subcommands: list, status, install, doctor

set -g script_name "aho-aur"
set -g project_root (dirname (dirname (realpath (status filename))))
set -g pkg_file "$project_root/artifacts/harness/aur-packages.txt"

function _info
    set_color cyan; echo "[$script_name] $argv"; set_color normal
end

function _warn
    set_color yellow; echo "[$script_name WARN] $argv"; set_color normal
end

function _error
    set_color red; echo "[$script_name ERROR] $argv"; set_color normal
end

function _gap
    set_color red; echo "[CAPABILITY GAP] $argv"; set_color normal
end

function _parse_packages
    if not test -f $pkg_file
        _error "Package list not found: $pkg_file"
        return 1
    end
    grep -v '^\s*#' $pkg_file | grep -v '^\s*$' | string trim; or true
end

function _ensure_yay
    if command -q yay
        return 0
    end
    _info "yay not found. Bootstrapping from AUR..."
    set -l tmpdir (mktemp -d)
    git clone https://aur.archlinux.org/yay.git $tmpdir/yay
    if test $status -ne 0
        _gap "Failed to clone yay from AUR. Check network."
        rm -rf $tmpdir
        return 1
    end
    pushd $tmpdir/yay
    makepkg -si --noconfirm
    set -l build_status $status
    popd
    rm -rf $tmpdir
    if test $build_status -ne 0
        _gap "yay build failed."
        return 1
    end
    _info "yay bootstrapped successfully."
end

function _cmd_list
    set -l pkgs (_parse_packages)
    if test (count $pkgs) -eq 0
        _info "No AUR packages declared."
        return 0
    end
    for pkg in $pkgs
        echo $pkg
    end
end

function _cmd_status
    set -l pkgs (_parse_packages)
    if test (count $pkgs) -eq 0
        _info "No AUR packages declared."
        return 0
    end
    set -l installed 0
    set -l missing 0
    for pkg in $pkgs
        if pacman -Qi $pkg >/dev/null 2>&1
            set_color green; echo "  [installed] $pkg"; set_color normal
            set installed (math $installed + 1)
        else
            set_color red; echo "  [missing]   $pkg"; set_color normal
            set missing (math $missing + 1)
        end
    end
    _info "$installed installed, $missing missing out of "(count $pkgs)" declared packages"
end

function _cmd_install
    set -l pkgs (_parse_packages)
    if test (count $pkgs) -eq 0
        _info "No AUR packages declared. Nothing to install."
        return 0
    end
    _ensure_yay; or return 1
    _info "Installing "(count $pkgs)" AUR packages via yay..."
    yay -S --needed $pkgs
    if test $status -ne 0
        _gap "yay install failed."
        return 1
    end
    _info "AUR package installation complete."
end

function _cmd_doctor
    set -l pkgs (_parse_packages)
    if test (count $pkgs) -eq 0
        _info "No AUR packages declared. Doctor pass."
        return 0
    end
    set -l missing
    for pkg in $pkgs
        if not pacman -Qi $pkg >/dev/null 2>&1
            set -a missing $pkg
        end
    end
    if test (count $missing) -gt 0
        _error "Missing AUR packages: $missing"
        return 1
    end
    _info "All "(count $pkgs)" declared AUR packages present."
    return 0
end

switch "$argv[1]"
    case list
        _cmd_list
    case status
        _cmd_status
    case install
        _cmd_install
    case doctor
        _cmd_doctor
    case '*'
        echo "Usage: $script_name {list|status|install|doctor}"
        exit 1
end
