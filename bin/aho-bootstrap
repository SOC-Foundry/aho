#!/usr/bin/env fish
# aho-bootstrap - Idempotent environment installer for aho.
# 0.2.1 — replaces 0.1.14 skeleton.

set -l script_version "0.2.9"

function _info
    set_color cyan; echo "[aho-bootstrap] $argv"; set_color normal
end

function _warn
    set_color yellow; echo "[aho-bootstrap WARN] $argv"; set_color normal
end

function _error
    set_color red; echo "[aho-bootstrap ERROR] $argv"; set_color normal
end

function _gap
    set_color red; echo "[CAPABILITY GAP] $argv"; set_color normal
end

# 1. Platform check
if not test -f /etc/arch-release
    _gap "Arch Linux required (/etc/arch-release not found). Halt."
    exit 1
end

if not type -q fish
    _gap "fish shell required. Halt."
    exit 1
end

_info "Platform: Arch Linux + fish. OK."

# 2. Resolve project root
set -l project_root (dirname (dirname (realpath (status filename))))
_info "Project root: $project_root"

# 3. Create XDG directories (idempotent)
set -l dirs \
    $HOME/.local/bin \
    $HOME/.config/aho \
    $HOME/.config/systemd/user \
    $HOME/.local/share/aho \
    $HOME/.local/share/aho/traces

for d in $dirs
    mkdir -p $d
end
_info "XDG directories ready."

# 4. Generate .mcp.json from template (idempotent)
set -l mcp_template "$project_root/.mcp.json.tpl"
set -l mcp_target "$project_root/.mcp.json"
if test -f $mcp_template
    if test -f $mcp_target; and not contains -- --force $argv
        _info ".mcp.json already exists (use --force to regenerate)."
    else
        string replace -a '{{PROJECT_ROOT}}' $project_root < $mcp_template > $mcp_target
        _info ".mcp.json generated from template."
    end
else
    _warn ".mcp.json.tpl not found at $mcp_template — skipping MCP config generation."
end

# 5. Per-clone age key (idempotent)
if not test -f $HOME/.config/aho/age.key
    if command -q age-keygen
        age-keygen -o $HOME/.config/aho/age.key
        chmod 600 $HOME/.config/aho/age.key
        _gap "age key generated at ~/.config/aho/age.key"
        echo "BACK IT UP NOW. Without it, all encrypted secrets are unrecoverable."
        exit 1
    else
        _gap "age-keygen not found. Install age: sudo pacman -S age"
        exit 1
    end
else
    _info "Age key present."
end

# 6. pip install (idempotent)
_info "Installing aho Python package..."
cd $project_root
pip install -e . --break-system-packages --quiet 2>&1
if test $status -ne 0
    _error "pip install failed."
    exit 1
end
_info "Python package installed."

# 7. Symlink bin wrappers (idempotent)
for wrapper in (command ls $project_root/bin/)
    if test "$wrapper" = "aho-bootstrap"; or test "$wrapper" = "aho-uninstall"
        continue
    end
    set -l src "$project_root/bin/$wrapper"
    set -l dest "$HOME/.local/bin/$wrapper"
    ln -sf $src $dest
end
_info "Bin wrappers linked."

# 8. Install MCP server fleet (global npm packages, 9 servers per 0.2.4 registry)
_info "Checking MCP server fleet..."
set -l mcp_packages \
    firebase-tools \
    @upstash/context7-mcp \
    firecrawl-mcp \
    @playwright/mcp \
    @modelcontextprotocol/server-filesystem \
    @modelcontextprotocol/server-memory \
    @modelcontextprotocol/server-sequential-thinking \
    @modelcontextprotocol/server-everything

for pkg in $mcp_packages
    if not npm list -g $pkg 2>/dev/null | grep -q $pkg
        _info "Installing $pkg..."
        sudo npm install -g $pkg; or _gap "sudo npm install failed for $pkg"
    end
end
_info "MCP fleet checked."

# 9. Install systemd user services for aho daemons
_info "Installing systemd user services..."
for daemon in openclaw nemoclaw telegram harness-watcher otel-collector jaeger dashboard
    set -l template "$project_root/templates/systemd/aho-$daemon.service.template"
    set -l dest "$HOME/.config/systemd/user/aho-$daemon.service"
    if test -f $template
        cp $template $dest
        _info "  Installed aho-$daemon.service"
    else
        _warn "  Template missing: $template"
    end
end
# Copy OTEL collector config
if test -f "$project_root/templates/otelcol-config.yaml"
    cp "$project_root/templates/otelcol-config.yaml" "$HOME/.local/share/aho/otelcol-config.yaml"
    _info "  OTEL collector config installed."
end
systemctl --user daemon-reload
systemctl --user enable --now aho-openclaw aho-nemoclaw aho-telegram aho-harness-watcher 2>/dev/null; or true
_info "Systemd user services installed and enabled."

# 10. Verify linger
set -l linger_status (loginctl show-user $USER --property=Linger 2>/dev/null | string replace 'Linger=' '')
if test "$linger_status" != "yes"
    _gap "Linger not enabled. Run: sudo loginctl enable-linger $USER"
    exit 1
end
_info "Linger enabled for $USER."

# 11. Fish config marker (idempotent)
set -l config_fish "$HOME/.config/fish/config.fish"
set -l marker_begin "# >>> aho >>>"
if test -f $config_fish
    if not grep -q "$marker_begin" $config_fish
        _info "Adding aho block to config.fish"
        printf '\n%s\n' "$marker_begin" >> $config_fish
        printf '%s\n' "# Managed by aho install." >> $config_fish
        printf 'set -gx AHO_PROJECT_ROOT "%s"\n' "$project_root" >> $config_fish
        printf 'if test -d "$AHO_PROJECT_ROOT/bin"\n' >> $config_fish
        printf '    fish_add_path "$AHO_PROJECT_ROOT/bin"\n' >> $config_fish
        printf 'end\n' >> $config_fish
        printf '%s\n' "# <<< aho <<<" >> $config_fish
    else
        _info "Fish config marker already present."
    end
end

# 12. Summary
_info "---"
_info "aho $script_version install complete."
_info "  Python package: editable install"
_info "  XDG dirs: created"
_info "  Bin wrappers: linked to ~/.local/bin/"
_info "  Linger: enabled"
_info "  Systemd user dir: ready"
_info "---"
_info "Next: run 'aho doctor' to verify environment."
